{
  "compilerOptions": {
    "module": "esnext",
    "target": "ES2020",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "skipLibCheck": true,
    "strictFunctionTypes": false,
    "typeRoots": ["./shims", "./node_modules/@types"]
  }
}
