{
  "name": "@michalkuzma01/node-red-ksef",
  "version": "0.0.1",
  "author": "Michał Kuźma <michal@kuzma.it>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichalKuzma21/ksed-node-red-contrib/"
  },
  "homepage": "https://github.com/MichalKuzma21/ksed-node-red-contrib/#readme",
  "bugs": {
    "url": "https://github.com/MichalKuzma21/ksed-node-red-contrib/"
  },
  "description": "Krajowy System e-Faktur (KSeF) integration for Node-RED",
  "type": "commonjs",
  "keywords": [
    "node-red",
    "ksef",
    "invoices"
  ],
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "node-red": {
    "nodes": {
      "authentication": "authentication.js",
      "send-invoice": "send-invoice.js",
      "invoices-metadata-hwm-sync": "invoices-metadata-hwm-sync.js",
      "invoice-visualization": "invoice-visualization.js",
      "refresh-token": "refresh-token.js",
      "download-invoice": "download-invoice.js",
      "init-session": "init-interactive-session.js",
      "close-session": "close-interactive-session.js"
    }
  },
  "files": [
    "*.js",
    "*.html",
    "hey-api-generated-ksef-client",
    "LICENCE.txt",
    "README.md"
  ],
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest --config vitest.config.ts",
    "test:e2e": "vitest --config vitest.e2e.config.ts",
    "openapi": "openapi-ts --output ./hey-api-generated-ksef-client --input https://ksef-test.mf.gov.pl/docs/v2/openapi.json",
    "build": "rollup -c",
    "prepare:dist": "rm -rf dist && mkdir dist && npm run build && npm run copy:html && cp package.json dist/ && cp LICENCE.txt dist/ && cp README.md dist/",
    "copy:html": "find src/nodes -name '*.html' -exec cp {} dist/ \\;",
    "bump:patch": "npm version patch --no-git-tag-version",
    "pack": "npm pack ./dist",
    "release:local": "npm run bump:patch && npm run prepare:dist && npm run pack && ./upload.sh michalkuzma01-node-red-ksef-$(npm pkg get version | tr -d '\"').tgz",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{js,ts,html,json,md}'",
    "format:check": "prettier --check '**/*.{js,ts,html,json,md}'"
  },
  "dependencies": {
    "@akmf/ksef-fe-invoice-converter": "github:CIRFMF/ksef-pdf-generator#f48680a",
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "@peculiar/webcrypto": "^1.5.0",
    "@peculiar/x509": "^1.13.0",
    "effect": "^3.19.8",
    "qrcode": "^1.5.4",
    "xadesjs": "^2.6.3",
    "xmlbuilder2": "^4.0.1",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.0",
    "@hey-api/openapi-ts": "0.88.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node-red": "^1.3.5",
    "@types/nunjucks": "^3.2.6",
    "@types/xmldom": "^0.1.34",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.1",
    "rollup": "^3.29.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4",
    "xmldom": "^0.6.0"
  }
}
